# Local server
PORT=3456
JWT_SECRET=replace-with-a-long-random-secret

# Real provider switches are disabled by default.
ENABLE_REAL_AI=false
ENABLE_REAL_EMAIL=false
ENABLE_REAL_PAYMENT=false
ENABLE_REAL_STORAGE=false

# OpenAI-compatible AI provider placeholders.
AI_API_BASE=https://your-provider.example.com/v1
AI_IMAGE_KEY=sk-replace-with-image-key
AI_TEXT_KEY=sk-replace-with-text-key
AI_IMAGE_MODEL=gpt-image-2
AI_TEXT_MODEL=gpt-5.5
