# Local server
PORT=3456
# Optional Docker host port. Keep PORT as the container/app port; use HOST_PORT when local 3456 is already occupied.
HOST_PORT=3456
JWT_SECRET=replace-with-a-long-random-secret

# Docker build image. Use full Debian image because better-sqlite3 may need native build tools.
NODE_IMAGE=node:20-bookworm

# Runtime paths. Keep defaults for local npm start; Docker Compose overrides them.
DATA_DIR=.
DB_PATH=./data.db
UPLOAD_DIR=./uploads
LOG_DIR=./logs

# Real provider switches are disabled by default.
ENABLE_REAL_AI=false
ENABLE_REAL_EMAIL=false
ENABLE_REAL_PAYMENT=false
ENABLE_REAL_STORAGE=false

# OpenAI-compatible AI provider placeholders.
# The preferred production path is Provider Adapter -> New-API -> CPA/upstream providers.
AI_PROVIDER_GATEWAY=new-api
NEW_API_BASE=https://your-new-api.example.com/v1
NEW_API_KEY=sk-replace-with-new-api-token
PROVIDER_TIMEOUT_MS=30000
AI_API_BASE=https://your-provider.example.com/v1
AI_IMAGE_KEY=sk-replace-with-image-key
AI_TEXT_KEY=sk-replace-with-text-key
AI_IMAGE_MODEL=gpt-image-2
AI_TEXT_MODEL=gpt-5.5
