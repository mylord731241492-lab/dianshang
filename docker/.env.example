# Copy this file to .env before running docker compose.

# App port inside container and host port exposed to LAN.
PORT=3456
HOST_PORT=3456

# Replace before internal production use.
JWT_SECRET=replace-with-a-long-random-secret

# AI provider. Keep false for dry-run/mock mode.
ENABLE_REAL_AI=false
AI_PROVIDER_GATEWAY=new-api
NEW_API_BASE=https://your-new-api.example.com/v1
NEW_API_KEY=sk-replace-with-new-api-token
AI_IMAGE_MODEL=gpt-image-2
AI_TEXT_MODEL=gpt-5.5

# Optional direct provider keys kept for compatibility.
AI_API_BASE=https://your-provider.example.com/v1
AI_IMAGE_KEY=sk-replace-with-image-key
AI_TEXT_KEY=sk-replace-with-text-key

# Provider timeouts.
PROVIDER_TIMEOUT_MS=120000
ECOMMERCE_TEXT_PROVIDER_TIMEOUT_MS=240000
IMAGE_PROVIDER_TIMEOUT_MS=180000
CANVAS_DIALOG_ANALYSIS_TIMEOUT_MS=120000
IMAGE_PROVIDER_REQUEST_DELAY_MS=1500
# 可选：仅代理 lingsuan.top 图片请求，不设置容器全局 HTTP(S)_PROXY。
LINGSUAN_IMAGE_PROXY_URL=
# Not enabled in the current internal test phase.
ENABLE_REAL_EMAIL=false
ENABLE_REAL_PAYMENT=false
ENABLE_REAL_STORAGE=false

# Fixed internal Chat stack. Replace every secret before startup.
ENABLE_LIBRECHAT=true
LIBRECHAT_BRIDGE_SECRET=replace-with-32-byte-random-secret
LIBRECHAT_JWT_SECRET=replace-with-32-byte-random-secret
LIBRECHAT_JWT_REFRESH_SECRET=replace-with-another-32-byte-random-secret
LIBRECHAT_CREDS_KEY=replace-with-64-hex-character-key
LIBRECHAT_CREDS_IV=replace-with-32-hex-character-iv
LIBRECHAT_SSO_TTL_SECONDS=60
LIBRECHAT_INTERNAL_URL=http://librechat:3080
CHAT_GATEWAY_PORT=3456
CHAT_PUBLIC_ORIGIN=http://192.168.0.39:3456

# Build base image. Leave as-is unless the internal network needs a mirror.
NODE_IMAGE=node:20-bookworm
